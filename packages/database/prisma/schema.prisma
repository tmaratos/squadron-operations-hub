generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SquadronRole {
  COMMANDER
  DEPUTY_COMMANDER
  ADMINISTRATION
  PERSONNEL
  FINANCE
  LOGISTICS
  SAFETY
  AEROSPACE_EDUCATION
  CADET_PROGRAMS
  EMERGENCY_SERVICES
  COMMUNICATIONS
  IT_SYSTEMS
  PUBLIC_AFFAIRS
  RECRUITING_RETENTION
  MEMBER
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  AWAITING_APPROVAL
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FundingStatus {
  PROSPECT
  RESEARCHING
  CONTACTED
  APPLICATION_IN_PROGRESS
  SUBMITTED
  AWARDED
  DECLINED
  CLOSED
}

enum InventoryCondition {
  SERVICEABLE
  NEEDS_MAINTENANCE
  UNSERVICEABLE
  MISSING
  RETIRED
}

enum InspectionStatus {
  DRAFT
  IN_PROGRESS
  READY_FOR_REVIEW
  COMPLETED
  ARCHIVED
}

enum InspectionItemStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLIANT
  FINDING
  NOT_APPLICABLE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  DISCORD
  SMS
}

model Squadron {
  id          String   @id @default(cuid())
  charterCode String   @unique
  name        String
  timezone    String   @default("America/New_York")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships            SquadronMembership[]
  functionalAreas        FunctionalArea[]
  tasks                  Task[]
  complianceRequirements ComplianceRequirement[]
  documents              Document[]
  discordChannels        DiscordChannel[]
  auditEvents            AuditEvent[]
  meetings               Meeting[]
  processes               ProcessDefinition[]
  inventoryItems         InventoryItem[]
  fundingOpportunities   FundingOpportunity[]
  contacts                Contact[]
  inspections             Inspection[]
  calendarEvents          CalendarEvent[]
  notifications           Notification[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  SquadronMembership[]
  assignedTasks Task[]      @relation("TaskOwner")
  auditEvents   AuditEvent[] @relation("AuditActor")
  notifications Notification[]
}

model SquadronMembership {
  id         String       @id @default(cuid())
  squadronId String
  userId     String
  role       SquadronRole
  isActive   Boolean      @default(true)
  startsAt   DateTime     @default(now())
  endsAt     DateTime?
  createdAt  DateTime     @default(now())

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([squadronId, userId, role])
  @@index([squadronId])
  @@index([userId])
}

model FunctionalArea {
  id          String   @id @default(cuid())
  squadronId  String
  key         String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  squadron       Squadron               @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  tasks          Task[]
  processes      ProcessDefinition[]
  inspectionItems InspectionItem[]

  @@unique([squadronId, key])
}

model Task {
  id               String       @id @default(cuid())
  squadronId       String
  functionalAreaId String?
  ownerUserId      String?
  title            String
  description      String?
  status           TaskStatus   @default(OPEN)
  priority         TaskPriority @default(NORMAL)
  dueAt            DateTime?
  sourceType       String?
  sourceReference  String?
  blockedReason    String?
  completionNotes  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  completedAt      DateTime?

  squadron       Squadron        @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  functionalArea FunctionalArea? @relation(fields: [functionalAreaId], references: [id])
  owner           User?           @relation("TaskOwner", fields: [ownerUserId], references: [id])
  meetingActions  MeetingAction[]

  @@index([squadronId, status])
  @@index([ownerUserId])
  @@index([dueAt])
}

model ComplianceRequirement {
  id                String   @id @default(cuid())
  squadronId        String
  name              String
  description       String?
  governingSource   String?
  responsibleRole   String?
  recurrenceRule    String?
  leadTimeDays      Int      @default(14)
  nextDueAt         DateTime?
  requiredEvidence  Json?
  approvalAuthority String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)

  @@index([squadronId, isActive])
  @@index([nextDueAt])
}

model Document {
  id             String        @id @default(cuid())
  squadronId     String
  title          String
  category       String?
  description    String?
  status         ContentStatus @default(DRAFT)
  currentVersion Int           @default(1)
  storageKey     String
  ownerUserId    String?
  governingSource String?
  reviewDueAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([squadronId, category])
  @@index([reviewDueAt])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    Int
  storageKey String
  notes      String?
  createdByUserId String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
}

model Meeting {
  id          String        @id @default(cuid())
  squadronId  String
  title       String
  description String?
  status      MeetingStatus @default(DRAFT)
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  agenda      Json?
  minutes     String?
  createdByUserId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  squadron Squadron       @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  actions  MeetingAction[]

  @@index([squadronId, startsAt])
}

model MeetingAction {
  id          String     @id @default(cuid())
  meetingId   String
  taskId      String?
  title       String
  ownerUserId String?
  dueAt       DateTime?
  status      TaskStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([meetingId, status])
}

model ProcessDefinition {
  id               String        @id @default(cuid())
  squadronId       String
  functionalAreaId String?
  title            String
  summary          String?
  status           ContentStatus @default(DRAFT)
  version          Int           @default(1)
  ownerUserId      String?
  steps            Json
  reviewDueAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  squadron       Squadron        @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  functionalArea FunctionalArea? @relation(fields: [functionalAreaId], references: [id])

  @@index([squadronId, status])
}

model InventoryItem {
  id             String             @id @default(cuid())
  squadronId     String
  assetTag       String?
  name           String
  category       String?
  description    String?
  quantity       Int                @default(1)
  reorderPoint   Int?
  location       String?
  condition      InventoryCondition @default(SERVICEABLE)
  assignedUserId String?
  acquiredAt     DateTime?
  lastInspectedAt DateTime?
  nextInspectionAt DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)

  @@unique([squadronId, assetTag])
  @@index([squadronId, category])
  @@index([nextInspectionAt])
}

model Contact {
  id           String   @id @default(cuid())
  squadronId   String
  name         String
  organization String?
  type         String?
  email        String?
  phone        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  fundingOpportunities FundingOpportunity[]

  @@index([squadronId, organization])
}

model FundingOpportunity {
  id             String        @id @default(cuid())
  squadronId     String
  contactId      String?
  name           String
  type           String?
  source         String?
  description    String?
  status         FundingStatus @default(PROSPECT)
  amountCents    Int?
  nextAction     String?
  nextActionAt   DateTime?
  applicationDueAt DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([squadronId, status])
  @@index([applicationDueAt])
}

model DiscordChannel {
  id          String   @id @default(cuid())
  squadronId  String
  guildId     String
  channelId   String
  displayName String
  purpose     String
  isActive    Boolean  @default(true)
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)

  @@unique([squadronId, channelId])
}

model Inspection {
  id          String           @id @default(cuid())
  squadronId  String
  title       String
  description String?
  status      InspectionStatus @default(DRAFT)
  startsAt    DateTime?
  dueAt       DateTime?
  completedAt DateTime?
  score       Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  squadron Squadron        @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  items    InspectionItem[]

  @@index([squadronId, status])
}

model InspectionItem {
  id               String               @id @default(cuid())
  inspectionId     String
  functionalAreaId String?
  title            String
  description      String?
  status           InspectionItemStatus @default(NOT_STARTED)
  ownerUserId      String?
  dueAt            DateTime?
  evidence         Json?
  finding          String?
  correctiveAction String?
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  inspection     Inspection      @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  functionalArea FunctionalArea? @relation(fields: [functionalAreaId], references: [id])

  @@index([inspectionId, status])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  squadronId  String
  title       String
  description String?
  eventType   String
  startsAt    DateTime
  endsAt      DateTime?
  recurrenceRule String?
  location    String?
  status      String   @default("SCHEDULED")
  linkedEntityType String?
  linkedEntityId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)

  @@index([squadronId, startsAt])
}

model Notification {
  id          String              @id @default(cuid())
  squadronId  String
  userId      String?
  channel     NotificationChannel @default(IN_APP)
  title       String
  body        String
  sourceType  String?
  sourceId    String?
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failureReason String?
  metadata    Json?
  createdAt   DateTime            @default(now())

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([squadronId, scheduledAt])
  @@index([userId, readAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  squadronId  String
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  squadron Squadron @relation(fields: [squadronId], references: [id], onDelete: Cascade)
  actor     User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([squadronId, createdAt])
  @@index([entityType, entityId])
}
